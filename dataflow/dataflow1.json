{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "adls_LS",
						"type": "LinkedServiceReference"
					},
					"name": "DimAirline"
				},
				{
					"linkedService": {
						"referenceName": "adls_LS",
						"type": "LinkedServiceReference"
					},
					"name": "DimFlight"
				},
				{
					"linkedService": {
						"referenceName": "adls_LS",
						"type": "LinkedServiceReference"
					},
					"name": "DimPassenger"
				},
				{
					"linkedService": {
						"referenceName": "adls_LS",
						"type": "LinkedServiceReference"
					},
					"name": "FactBookings"
				},
				{
					"linkedService": {
						"referenceName": "adls_LS",
						"type": "LinkedServiceReference"
					},
					"name": "DimAirport"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumnCountry"
				},
				{
					"name": "selectColumns1"
				},
				{
					"name": "derivedgenderflag"
				},
				{
					"name": "derivedgenderflag1"
				},
				{
					"name": "filtergreater25"
				},
				{
					"name": "changeNamestruct"
				}
			],
			"scriptLines": [
				"source(output(",
				"          airline_id as short,",
				"          airline_name as string,",
				"          country as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'On_prem_project/Bronze',",
				"     fileName: 'DimAirline.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> DimAirline",
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'On_prem_project/Bronze',",
				"     fileName: 'DimFlight.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> DimFlight",
				"source(output(",
				"          passenger_id as short,",
				"          full_name as string,",
				"          gender as string,",
				"          age as short,",
				"          country as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'On_prem_project/Bronze',",
				"     fileName: 'DimPassenger.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> DimPassenger",
				"source(output(",
				"          booking_id as short,",
				"          passenger_id as short,",
				"          flight_id as short,",
				"          airline_id as short,",
				"          origin_airport_id as short,",
				"          destination_airport_id as short,",
				"          booking_date as string,",
				"          ticket_cost as double,",
				"          flight_duration_mins as short,",
				"          checkin_status as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'On_prem_project/Bronze',",
				"     fileName: 'fact_bookings',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> FactBookings",
				"source(output(",
				"          airport_id as string,",
				"          airport_name as string,",
				"          city as string,",
				"          country as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'json',",
				"     fileSystem: 'landing',",
				"     folderPath: 'On_prem_project/Bronze',",
				"     fileName: 'DimAirport.json',",
				"     documentForm: 'documentPerLine') ~> DimAirport",
				"DimAirline derive(country = upper(country)) ~> derivedColumnCountry",
				"DimPassenger select(mapColumn(",
				"          passenger_id,",
				"          passenger_name = full_name,",
				"          gender_flag = gender,",
				"          age,",
				"          country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColumns1",
				"selectColumns1 derive(gender_flag = regexReplace(gender_flag, \"M\", \"Male\")) ~> derivedgenderflag",
				"derivedgenderflag derive(gender_flag = regexReplace(gender_flag, \"F\",\"Female\" )) ~> derivedgenderflag1",
				"derivedgenderflag1 filter(age > 25) ~> filtergreater25",
				"filtergreater25 derive(first_name = split(passenger_name, \" \")[1]) ~> changeNamestruct"
			]
		}
	}
}